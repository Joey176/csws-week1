        "\n",
        "CHALDEAN_ORDER = [\"SATURN\", \"JUPITER\", \"MARS\", \"SUN\", \"VENUS\", \"MERCURY\", \"MOON\"]\n",
        "WEEKDAY_LORDS = {0: \"MOON\", 1: \"MARS\", 2: \"MERCURY\", 3: \"JUPITER\", 4: \"VENUS\", 5: \"SATURN\", 6: \"SUN\"}\n",
        "ZODIAC_SIGNS = [\"ARI\", \"TAU\", \"GEM\", \"CAN\", \"LEO\", \"VIR\", \"LIB\", \"SCO\", \"SAG\", \"CAP\", \"AQU\", \"PIS\"]\n",
