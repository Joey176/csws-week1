        "        positions[name] = f\"{int(longitude % 30):02d}DG {ZODIAC_SIGNS[sign_index]} {retro_marker}\"\n",
        "    return positions\n",
        "\n",
        "# --- Main Engine Loop ---\n",
        "\n",
