        "    return current_hour_idx + 1, phase, CHALDEAN_ORDER[final_planet_idx], int(((start_time + (hour_length * (current_hour_idx + 1))) - now).total_seconds() / 60), int(hour_length.total_seconds() / 60), day_lord\n",
        "\n",
